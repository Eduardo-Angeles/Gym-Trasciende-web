// ═══════════════════════════════════════════════════════════════
//  PROMO TEMPORAL — Spinning Marzo 2026
// ═══════════════════════════════════════════════════════════════
const promosMarzoPlan = [
  {
    id: 1,
    title: "Dúo",
    subtitle: "Van en pareja o 2 amigos",
    price: "$450",
    priceDetail: "por persona / mes",
    icon: "🚴‍♀️🚴",
    badge: "Pareja",
    highlight: false,
    features: [
      "Inscripción sin costo",
      "2 personas inscritas juntas",
      "Clase de Spinning completa",
      "Acceso al área de spinning",
      "Horarios flexibles",
    ],
    savings: "Ahorra vs precio individual",
  },
  {
    id: 2,
    title: "Grupo",
    subtitle: "3 o más personas",
    price: "$420",
    priceDetail: "por persona / mes",
    icon: "🚴‍♂️🚴‍♀️🚴",
    badge: "Mejor Precio",
    highlight: true,
    features: [
      "Inscripción sin costo",
      "3 o más personas juntas",
      "Clase de Spinning completa",
      "Acceso al área de spinning",
      "Horarios flexibles",
    ],
    savings: "Máximo ahorro del mes",
  },
];

// ═══════════════════════════════════════════════════════════════
//  PROMOCIONES PERMANENTES
// ═══════════════════════════════════════════════════════════════
const promosPermanentes = [
  {
    id: 1,
    icon: "🎁",
    title: "Inscripción Gratis",
    description:
      "Sin costo de inscripción todo el año, para cualquier plan que elijas. Sin letra pequeña, solo pagas tu mensualidad.",
    badge: "Todo el Año",
    detail: "¡Ahorras $200!",
  },
  {
    id: 2,
    icon: "🎂",
    title: "Cumpleaños 10% Off",
    description:
      "Descuento del 10% en tu mensualidad durante todo tu mes de cumpleaños. Presenta identificación oficial y disfruta tu beneficio anual.",
    badge: "Especial",
    detail: "Cada año, tu mes",
  },
];

// ═══════════════════════════════════════════════════════════════
//  FAQ
// ═══════════════════════════════════════════════════════════════
const faqItems = [
  {
    question: "¿Hasta cuándo es válida la promo de Spinning de Marzo?",
    answer:
      "La promo de Spinning de Marzo está disponible durante todo el mes de marzo 2026. Debes inscribirte antes del 31 de marzo para aprovechar los precios especiales.",
  },
  {
    question: "¿Quiénes pueden participar en la promo de grupo?",
    answer:
      "Pueden inscribirse parejas, amigos o cualquier grupo de 2 o más personas. Lo importante es que se inscriban al mismo tiempo para aplicar la promo correspondiente.",
  },
  {
    question: "¿Cuál es la diferencia entre la promo Dúo y Grupo?",
    answer:
      "La promo Dúo aplica cuando se inscriben exactamente 2 personas juntas ($450 c/u). La promo Grupo aplica con 3 o más personas inscritas al mismo tiempo ($420 c/u), ofreciendo el mayor ahorro.",
  },
  {
    question: "¿Puedo combinar la promo de Spinning con el descuento de cumpleaños?",
    answer:
      "Las promociones temporales de Spinning de Marzo no son acumulables con el descuento de cumpleaños. Sin embargo, la inscripción gratis está siempre incluida en todos los planes.",
  },
  {
    question: "¿La inscripción siempre es gratis?",
    answer:
      "¡Sí! La inscripción es completamente gratis durante todo el año, sin importar el plan que elijas. Es nuestro compromiso para que inicies sin costos ocultos.",
  },
  {
    question: "¿Qué incluye el plan de Spinning?",
    answer:
      "Incluye acceso completo a las clases de Spinning, asesoría en técnica y postura, horarios flexibles (Lun-Vie 5am-10pm, Sáb 6:30am-5pm, Dom 12pm-4pm) y todos los beneficios del gimnasio.",
  },
  {
    question: "¿Necesito llevar algo especial a las clases de Spinning?",
    answer:
      "Recomendamos ropa cómoda para ejercicio, zapatos deportivos con suela firme, toalla y botella de agua. En el gym encontrarás bicicletas de spinning disponibles para tus sesiones.",
  },
];

// ═══════════════════════════════════════════════════════════════
//  PASOS
// ═══════════════════════════════════════════════════════════════
const steps = [
  {
    number: 1,
    title: "Reúne a tu grupo",
    description:
      "Invita a tu pareja, amigo o arma un grupo de 3 o más para pedalear juntos y ahorrar más.",
  },
  {
    number: 2,
    title: "Contáctanos",
    description:
      "Escríbenos por redes o visítanos antes del 31 de marzo. Te confirmamos disponibilidad de horarios.",
  },
  {
    number: 3,
    title: "Inscríbanse juntos",
    description:
      "Completen su inscripción al mismo tiempo y disfruten el precio de grupo desde el primer día.",
  },
];

// ═══════════════════════════════════════════════════════════════
//  NAV MÓVIL
// ═══════════════════════════════════════════════════════════════
const mobileNavItems = [
  {
    id: "promo-spinning",
    label: "Spinning",
    href: "#promo-spinning",
    icon: "clock" as const,
  },
  {
    id: "permanentes",
    label: "Siempre",
    href: "#promociones-permanentes",
    icon: "tag" as const,
  },
  {
    id: "faq",
    label: "FAQ",
    href: "#faq",
    icon: "grid" as const,
  },
  {
    id: "inscribirse",
    label: "Inscríbete",
    href: "/contacto",
    icon: "star" as const,
  },
];
---

<Layout
  title="Promociones Marzo 2026 | Gym Trasciende — Spinning en Grupo Ocotlán"
  description="Promo Spinning Marzo 2026 en Trasciende Gym Ocotlán. Ven en pareja por $450 c/u o en grupo de 3+ por $420 c/u. Inscripción gratis siempre."
  keywords="promociones spinning gym, descuento spinning ocotlán, promo grupo spinning 2026, gym spinning oferta, inscripción gratis gym trasciende"
  type="website"
>
  {/* ═══════════════════════════════════════════════════════
      SECCIÓN 1 — HERO (gradiente direccional)
      ═══════════════════════════════════════════════════════ */}
  <section
    class="bg-background relative min-h-screen overflow-hidden"
    aria-label="Promo Spinning Marzo 2026"
  >
    {/* Imagen de fondo */}
    <img
      src="/spining1.webp"
      alt=""
      class="absolute inset-0 h-full w-full object-cover object-center"
      loading="eager"
      aria-hidden="true"
    />

    {/* Mobile: overlay sólido oscuro sobre toda la imagen */}
    <div class="from-background/95 via-background/85 absolute inset-0 bg-linear-to-t to-background/40 lg:hidden">
    </div>

    {/* Desktop: gradiente de izquierda (oscuro) a derecha (transparente) */}
    <div class="from-background via-background/90 absolute inset-0 hidden bg-linear-to-r to-transparent lg:block">
    </div>

    {/* Fade inferior en ambos breakpoints */}
    <div class="from-background absolute inset-x-0 bottom-0 h-32 bg-linear-to-t to-transparent">
    </div>

    {/* Contenido */}
    <div class="relative z-10 flex min-h-screen items-center">
      <div class="mx-auto w-full max-w-7xl px-4 py-28 lg:py-0">
        <div class="flex max-w-2xl flex-col gap-7">
          {/* Badge */}
          <div class="inline-flex items-center gap-3">
            <div class="bg-primary h-px w-10 animate-pulse"></div>
            <span
              class="border-primary/40 bg-primary/10 text-primary rounded-full border px-4 py-1.5 text-xs font-semibold tracking-widest uppercase"
            >
              Promoción · Marzo 2026
            </span>
          </div>

          {/* Título */}
          <h1
            class="text-5xl leading-[1.05] font-black tracking-tight text-white md:text-7xl lg:text-8xl"
          >
            Spinning
            <span
              class="from-primary to-primary/60 block bg-linear-to-r bg-clip-text text-transparent"
            >
              en Grupo
            </span>
          </h1>

          {/* Eslogan */}
          <p class="max-w-xl text-lg leading-relaxed text-zinc-300 md:text-xl">
            Este marzo pedalea acompañado y paga menos. Trae a tu pareja o arma
            un grupo y aprovecha el precio especial de temporada.
          </p>

          {/* CTAs */}
          <div class="flex flex-col gap-4 pt-2 sm:flex-row">
            <a
              href="#promo-spinning"
              class="group border-primary text-primary hover:bg-primary/20 inline-flex items-center justify-center gap-2 rounded-xl border-2 px-6 py-3.5 font-bold transition-all duration-300 hover:scale-105 active:scale-95"
            >
              <span class="text-base font-semibold">Ver Promoción</span>
              <ButtonAnimation
                width={22}
                height={22}
                class="transition-transform group-hover:scale-110"
              />
            </a>

            <a
              href="/contacto"
              class="group border-secondary text-secondary hover:bg-secondary/10 inline-flex items-center justify-center gap-2 rounded-xl border-2 px-6 py-3.5 font-bold transition-all duration-300 hover:scale-105 active:scale-95"
            >
              <span class="text-base font-semibold">Inscribirme ahora</span>
              <ArrowAnimation class="size-5" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════
      SECCIÓN 2 — PROMO SPINNING MARZO
      ═══════════════════════════════════════════════════════ */}
  <SectionContainer class="py-20 md:py-28">
    <div id="promo-spinning" class="mx-auto max-w-7xl">
      {/* Header */}
      <div class="mb-14 text-center">
        <span
          class="border-primary/30 bg-primary/10 text-primary mb-4 inline-block rounded-full border px-4 py-1 text-xs font-semibold tracking-widest uppercase"
        >
          Promo del Mes
        </span>
        <h2 class="text-3xl font-black text-white md:text-5xl">
          Spinning de{" "}
          <span class="text-primary">Marzo</span>
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-zinc-400">
          Inscríbanse juntos y pedaleen con más motivación — y mejor precio.
          Todas las promos incluyen inscripción gratis.
        </p>
      </div>

      {/* Countdown */}
      <div class="mb-12 flex justify-center">
        <div
          class="border-primary/20 bg-zinc-900/60 rounded-2xl border px-8 py-5 backdrop-blur-sm"
        >
          <p
            class="text-primary mb-4 text-center text-xs font-semibold tracking-widest uppercase"
          >
            Tiempo restante de la promo
          </p>
          <CountdownTimer client:load targetDate="2026-03-31T23:59:59" />
        </div>
      </div>

      {/* Tarjetas */}
      <div class="mx-auto grid max-w-4xl gap-6 md:grid-cols-2">
        {
          promosMarzoPlan.map((plan) => (
            <article
              class:list={[
                "group relative flex flex-col overflow-hidden rounded-3xl border backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl",
                plan.highlight
                  ? "border-primary bg-zinc-900/80 hover:border-primary hover:shadow-primary/20"
                  : "border-primary/20 bg-zinc-900/60 hover:border-primary/50 hover:shadow-primary/10",
              ]}
            >
              {/* Badge */}
              <div class="absolute top-5 right-5 z-10">
                <span
                  class:list={[
                    "rounded-full px-3 py-1 text-xs font-black tracking-widest uppercase",
                    plan.highlight
                      ? "bg-primary text-black"
                      : "border-primary/50 border bg-primary/10 text-primary",
                  ]}
                >
                  {plan.badge}
                </span>
              </div>

              <div class="p-8">
                {/* Icono */}
                <div class="mb-5 text-4xl transition-transform duration-300 group-hover:scale-110">
                  {plan.icon}
                </div>

                {/* Título + subtítulo */}
                <h3 class="mb-1 text-2xl font-black text-white">{plan.title}</h3>
                <p class="text-primary mb-5 text-sm font-semibold">
                  {plan.subtitle}
                </p>

                {/* Precio */}
                <div class="mb-1 flex items-baseline gap-2">
                  <span
                    class:list={[
                      "text-5xl font-black tabular-nums",
                      plan.highlight ? "text-primary" : "text-white",
                    ]}
                  >
                    {plan.price}
                  </span>
                </div>
                <p class="mb-6 text-sm text-zinc-500">{plan.priceDetail}</p>

                {/* Separador */}
                <div class="border-primary/20 mb-6 border-t border-dashed" />

                {/* Features */}
                <ul class="mb-8 space-y-3">
                  {plan.features.map((feature) => (
                    <li class="flex items-center gap-3">
                      <svg
                        class="text-primary h-4 w-4 shrink-0"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                        aria-hidden="true"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                          clip-rule="evenodd"
                        />
                      </svg>
                      <span class="text-sm text-zinc-300">{feature}</span>
                    </li>
                  ))}
                </ul>

                {/* Nota de ahorro */}
                <p class="text-primary/70 mb-5 text-xs font-semibold tracking-wide">
                  ✦ {plan.savings}
                </p>

                {/* CTA */}
                <a
                  href="/contacto"
                  class:list={[
                    "block w-full rounded-xl py-3.5 text-center text-sm font-bold transition-all duration-300 hover:scale-[1.02]",
                    plan.highlight
                      ? "bg-primary text-black hover:bg-[#c5eb00]"
                      : "border-primary/50 text-primary border bg-primary/10 hover:bg-primary/20",
                  ]}
                >
                  Inscribirme con este plan
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </SectionContainer>

  {/* ═══════════════════════════════════════════════════════
      SECCIÓN 3 — PROMOCIONES PERMANENTES
      ═══════════════════════════════════════════════════════ */}
  <SectionContainer class="py-20 md:py-28">
    <div id="promociones-permanentes" class="mx-auto max-w-7xl">
      {/* Header */}
      <div class="mb-14 text-center">
        <span
          class="mb-4 inline-block rounded-full border border-zinc-700 bg-zinc-800/60 px-4 py-1 text-xs font-semibold tracking-widest text-zinc-400 uppercase"
        >
          Sin Fecha Límite
        </span>
        <h2 class="text-3xl font-black text-white md:text-5xl">
          Disponibles <span class="text-zinc-400">Todo el Año</span>
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-zinc-400">
          Sin trucos, sin letra pequeña. Estas promociones siempre están activas
          para ti.
        </p>
      </div>

      <div class="mx-auto grid max-w-4xl gap-6 md:grid-cols-2">
        {
          promosPermanentes.map((promo) => (
            <article class="group border-zinc-800 hover:border-primary/30 hover:shadow-primary/5 relative overflow-hidden rounded-3xl border bg-zinc-900/60 p-8 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:bg-zinc-900/80 hover:shadow-xl">
              {/* Badge */}
              <div class="absolute top-5 right-5">
                <span class="rounded-full border border-zinc-700 bg-zinc-800 px-3 py-1 text-xs font-semibold tracking-wide text-zinc-400 uppercase">
                  {promo.badge}
                </span>
              </div>

              {/* Icono */}
              <div class="bg-primary/10 mb-5 flex h-14 w-14 items-center justify-center rounded-2xl text-2xl transition-transform duration-300 group-hover:scale-110">
                {promo.icon}
              </div>

              <h3 class="mb-3 text-xl font-black text-white">{promo.title}</h3>
              <p class="mb-5 leading-relaxed text-zinc-400">{promo.description}</p>

              {/* Detail tag */}
              <div class="inline-flex items-center gap-2">
                <div class="bg-primary h-px w-6 transition-all duration-300 group-hover:w-10" />
                <span class="text-primary text-xs font-bold tracking-wide uppercase">
                  {promo.detail}
                </span>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </SectionContainer>

  {/* ═══════════════════════════════════════════════════════
      SECCIÓN 4 — CÓMO APROVECHAR
      ═══════════════════════════════════════════════════════ */}
  <SectionContainer
    backgroundImage="linear-gradient(rgba(0,0,0,0.82), rgba(0,0,0,0.82)), url('/fondofijo.webp')"
    fixedBackground={true}
    class="py-20 md:py-24"
  >
    <div class="mx-auto max-w-7xl">
      <div class="mb-14 text-center">
        <span
          class="border-primary/30 bg-primary/10 text-primary mb-4 inline-block rounded-full border px-4 py-1 text-xs font-semibold tracking-widest uppercase"
        >
          Es muy sencillo
        </span>
        <h2 class="text-3xl font-black text-white md:text-5xl">
          ¿Cómo Aprovechar la Promo?
        </h2>
      </div>

      <div class="grid gap-10 md:grid-cols-3">
        {
          steps.map((step) => (
            <div class="group text-center transition-transform duration-300 hover:-translate-y-2">
              <div class="bg-primary mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-full shadow-lg transition-all duration-300 group-hover:scale-110 group-hover:shadow-xl group-hover:shadow-primary/40">
                <span class="text-3xl font-black text-black">{step.number}</span>
              </div>
              <h3 class="mb-3 text-lg font-black text-white">{step.title}</h3>
              <p class="leading-relaxed text-zinc-400">{step.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </SectionContainer>

  {/* ═══════════════════════════════════════════════════════
      SECCIÓN 5 — FAQ
      ═══════════════════════════════════════════════════════ */}
  <div id="faq">
    <FAQ items={faqItems} />
  </div>

  {/* ═══════════════════════════════════════════════════════
      SECCIÓN 6 — CTA FINAL
      ═══════════════════════════════════════════════════════ */}
  <SectionContainer class="py-20 md:py-28">
    <div class="mx-auto max-w-4xl">
      <div class="relative overflow-hidden rounded-3xl">
        {/* Imagen de fondo */}
        <img
          src="/soinning2.webp"
          alt=""
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
          aria-hidden="true"
        />
        <div
          class="from-background/97 via-background/90 absolute inset-0 bg-linear-to-br to-[#1a2500]/88"
        >
        </div>

        <div
          class="border-primary/25 relative z-10 rounded-3xl border p-10 text-center md:p-16"
        >
          {/* Ícono */}
          <div
            class="bg-primary/15 mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl"
          >
            <span class="text-3xl">🚴‍♀️</span>
          </div>

          <p
            class="text-primary mb-2 text-xs font-semibold tracking-widest uppercase"
          >
            Solo en Marzo 2026
          </p>
          <h2 class="mb-4 text-3xl font-black text-white md:text-5xl">
            Pedalea Juntos,<br />
            <span class="text-primary">Pagan Menos</span>
          </h2>
          <p class="mx-auto mb-8 max-w-xl text-lg leading-relaxed text-zinc-300">
            La promo de Spinning de Marzo vence el 31 de marzo. Inscríbete con
            tu grupo antes de que termine y aprovecha el mejor precio del mes.
          </p>

          <div
            class="flex flex-col items-center justify-center gap-4 sm:flex-row"
          >
            <a
              href="/contacto"
              class="bg-primary hover:bg-[#c5eb00] inline-flex w-full items-center justify-center gap-2 rounded-xl px-8 py-4 text-lg font-black text-black shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-xl hover:shadow-primary/30 sm:w-auto"
            >
              Inscribirme en Spinning
            </a>
            <a
              href="/reviews"
              class="border-primary/50 text-primary hover:bg-primary/10 inline-flex w-full items-center justify-center gap-2 rounded-xl border-2 px-8 py-4 text-lg font-bold transition-all duration-300 hover:scale-105 sm:w-auto"
            >
              Lo que dicen de nosotros
            </a>
          </div>

          <p class="mt-6 text-sm text-zinc-500">
            ✦ Inscripción gratis siempre &nbsp;·&nbsp; Promo válida hasta el
            31/03/2026
          </p>
        </div>
      </div>
    </div>
  </SectionContainer>

  {/* Navegación móvil inferior */}
  <MobileBottomNav
    client:load
    items={mobileNavItems}
    hideOnScroll={false}
    vibration={true}
  />
</Layout>
