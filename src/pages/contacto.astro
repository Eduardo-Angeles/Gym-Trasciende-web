    url: "https://www.tiktok.com/@trasciende.gym",
    description: "Videos · Tips de entrenamiento · Humor",
    color: "from-zinc-900 via-[#ff0050] to-[#00f2ea]",
    glow: "hover:shadow-pink-500/20",
    border: "border-zinc-600/30 hover:border-zinc-400/60",
    iconBg: "bg-zinc-900",
    hoverRow: "hover:bg-zinc-800/60",
    accentText: "group-hover:text-zinc-200",
    accentBorder: "group-hover:border-l-zinc-400",
    icon: `<svg class="h-6 w-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.22 8.22 0 004.84 1.56V6.79a4.85 4.85 0 01-1.07-.1z"/></svg>`,
  },
];

const schedule = [
  { days: "Lunes a Viernes", hours: "5:00 AM - 10:00 PM" },
  { days: "Sábado", hours: "6:30 AM - 5:00 PM" },
  { days: "Domingo", hours: "12:00 PM - 4:00 PM" },
];

const mobileNavItems = [
  {
    id: "servicios",
    label: "Servicios",
    href: "/servicios",
    icon: "grid" as const,
  },
  { id: "precios", label: "Precios", href: "#precios", icon: "tag" as const },
  {
    id: "promociones",
    label: "Promos",
    href: "/promociones",
    icon: "clock" as const,
  },
  {
    id: "galeria",
    label: "Galería",
    href: "#galeria",
    icon: "image" as const,
  },
  {
    id: "contacto",
    label: "Contacto",
    href: "#redes",
    icon: "star" as const,
  },
];
---

<Layout
  title="Contacto y Horarios | Gym Trasciende - Ocotlán de Morelos"
  description="¿Tienes dudas? Contacta a Trasciende Gym en Ocotlán de Morelos. Ubicación, horarios desde las 5 am y atención personalizada. ¡Visítanos y aclara tus dudas!"
>
  <meta
    slot="head"
    name="keywords"
    content="gym trasciende, gimnasio ocotlan, gym ocotlan de morelos, fitness ocotlan, entrenamiento personalizado oaxaca, horarios gym trasciende, ubicacion gym trasciende"
  />
  <link slot="head" rel="canonical" href="https://trasciendegym.com/contacto" />
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ExerciseGym",
      name: "Gym Trasciende",
      description:
        "Centro de fitness y entrenamiento en Ocotlán de Morelos, Oaxaca. Transformación física segura y sostenible.",
      image: "https://trasciendegym.com/logo.jpg",
      url: "https://trasciendegym.com/contacto",
      telephone: "+52-951-498-0492",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Guillermo Prieto Sur 45",
        addressLocality: "Ocotlán de Morelos",
        addressRegion: "Oaxaca",
        addressCountry: "MX",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 16.7951,
        longitude: -96.6737,
      },
      openingHoursSpecification: [
        {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          opens: "05:00",
          closes: "22:00",
        },
        {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: "Saturday",
          opens: "06:30",
          closes: "17:00",
        },
        {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: "Sunday",
          opens: "12:00",
          closes: "16:00",
        },
      ],
      sameAs: [
        "https://www.tiktok.com/@trasciende.gym",
        "https://www.instagram.com/trasciendegym",
        "https://www.facebook.com/profile.php?id=61583792785523",
      ],
      priceRange: "$$",
    })}
  />
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "¿Cuáles son los horarios de Gym Trasciende?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Lunes a Viernes: 5:00 AM - 10:00 PM. Sábado: 6:30 AM - 5:00 PM. Domingo: 12:00 PM - 4:00 PM.",
          },
        },
        {
          "@type": "Question",
          name: "¿Dónde está ubicado Gym Trasciende?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Estamos ubicados en Guillermo Prieto Sur 45, Ocotlán de Morelos, Oaxaca.",
          },
        },
        {
          "@type": "Question",
          name: "¿Cómo puedo contactar a Gym Trasciende?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Puedes contactarnos por WhatsApp al 951 498 0492, Instagram (@trasciendegym), Facebook o TikTok (@trasciende.gym) o visitarnos directamente.",
          },
        },
      ],
    })}
  />

  {
    /* ═══════════════════════════════════════════════════════════
      SECCIÓN 1 — HERO
      ═══════════════════════════════════════════════════════════ */
  }
  <section
    class="bg-background relative min-h-[60vh] overflow-hidden md:min-h-[65vh]"
    aria-label="Contacto Trasciende Gym"
  >
    {/* Fondo: imagen del gym con overlay oscuro */}
    <div class="absolute inset-0" aria-hidden="true">
      <img
        src="/hero/hero-2.webp"
        alt=""
        class="h-full w-full object-cover object-center"
        loading="eager"
      />
      <div
        class="from-background/60 via-background/80 to-background absolute inset-0 bg-linear-to-b"
      >
      </div>
      <div
        class="from-background/80 to-background/80 absolute inset-0 bg-linear-to-r via-transparent"
      >
      </div>
    </div>

    {/* Grain */}
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.03]"
      style="background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');background-size:200px"
    >
    </div>

    <div
      class="relative z-10 mx-auto max-w-7xl px-4 pt-28 pb-14 md:pt-36 md:pb-20"
    >
      <div class="mx-auto max-w-3xl text-center">
        {/* Badge */}
        <span
          class="border-primary/40 bg-primary/10 text-primary mb-6 inline-block rounded-full border px-4 py-1.5 text-xs font-semibold tracking-widest uppercase"
        >
          Ocotlán de Morelos, Oaxaca
        </span>

        {/* Logo */}
        <div class="mb-6 flex justify-center">
          <div
            class="border-primary/30 ring-primary/10 relative h-24 w-24 overflow-hidden rounded-full border-2 ring-4 md:h-28 md:w-28"
          >
            <img
              src="/logo.jpg"
              alt="Logo Gym Trasciende"
              class="h-full w-full object-cover"
              loading="eager"
            />
          </div>
        </div>

        <h1
          class="mb-4 text-4xl leading-[1.05] font-black tracking-tight text-white sm:text-5xl md:text-6xl lg:text-7xl"
        >
          Hablemos
          <span class="text-primary block"> Trasciende </span>
        </h1>

        <p class="mx-auto mb-8 max-w-xl text-lg leading-relaxed text-zinc-300">
          Estamos a un mensaje de distancia. Resuelve tus dudas, conoce los
          planes o visítanos directo en Ocotlán.
        </p>

        {/* CTA principal */}
        <div
          class="flex flex-col items-center justify-center gap-3 sm:flex-row"
        >
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-primary text-background hover:bg-primary/90 inline-flex w-full items-center justify-center gap-2 rounded-xl px-8 py-4 text-base font-bold shadow-lg shadow-black/30 transition-all duration-300 hover:scale-105 sm:w-auto"
          >
            <svg
              class="h-5 w-5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            Mensaje por WhatsApp
          </a>
          <a
            href="#ubicacion"
            class="border-primary/50 text-primary hover:bg-primary/10 inline-flex w-full items-center justify-center gap-2 rounded-xl border-2 px-8 py-4 text-base font-bold transition-all duration-300 hover:scale-105 sm:w-auto"
          >
            Ver horarios
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  {
    /* ═══════════════════════════════════════════════════════════
      SECCIÓN 2 — CANALES DE CONTACTO (lista compacta elegante)
      ═══════════════════════════════════════════════════════════ */
  }
  <div
    id="redes"
    class="mx-auto max-w-xl px-4 py-14 md:max-w-2xl md:py-20 lg:max-w-3xl"
  >
    <p
      class="text-primary mb-6 text-center text-xs font-semibold tracking-widest uppercase"
    >
      Encuéntranos aquí
    </p>
    <ul
      class="divide-y divide-zinc-800/70 overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900/50 backdrop-blur-sm"
    >
      {
        socialLinks.map((link) => (
          <li>
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "group flex items-center gap-5 border-l-4 border-l-transparent px-6 py-5 transition-all duration-200",
                link.hoverRow,
                link.accentBorder,
              ]}
            >
              {/* Ícono */}
              <div
                class:list={[
                  "flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl shadow-lg",
                  link.iconBg,
                ]}
                set:html={link.icon.replace('class="h-6 w-6', 'class="h-5 w-5')}
              />
              {/* Texto */}
              <div class="min-w-0 flex-1">
                <p
                  class:list={[
                    "text-base leading-tight font-bold text-white transition-colors duration-200",
                    link.accentText,
                  ]}
                >
                  {link.name}
                </p>
                <p class="mt-0.5 text-sm text-zinc-500">
                  <span class="font-medium text-zinc-400">{link.handle}</span>
                  <span class="mx-1.5 text-zinc-700">·</span>
                  {link.description}
                </p>
              </div>
              {/* Flecha */}
              <svg
                class:list={[
                  "h-5 w-5 shrink-0 text-zinc-600 transition-all duration-200 group-hover:translate-x-1",
                  link.accentText,
                ]}
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  {
    /* ═══════════════════════════════════════════════════════════
      SECCIÓN 4 — MAPA + HORARIOS (2 col)
      ═══════════════════════════════════════════════════════════ */
  }
  <SectionContainer id="ubicacion" class="py-16 md:py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 text-center">
        <span
          class="border-primary/30 bg-primary/10 text-primary mb-3 inline-block rounded-full border px-4 py-1 text-xs font-semibold tracking-widest uppercase"
        >
          Visítanos
        </span>
        <h2 class="text-3xl font-black text-white md:text-4xl">
          Ubicación y Horarios
        </h2>
      </div>

      <div class="grid gap-8 lg:grid-cols-2">
        {/* Horarios */}
        <div
          class="border-primary/20 flex flex-col justify-center rounded-3xl border bg-zinc-900/60 p-8"
        >
          <p
            class="text-primary mb-2 text-xs font-semibold tracking-widest uppercase"
          >
            Horario de Apertura
          </p>
          <h3 class="mb-6 text-2xl font-black text-white">
            Siempre hay un horario para ti
          </h3>
          <ScheduleSection schedule={schedule} />
          <div class="mt-6 flex flex-col gap-3">
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-primary text-background hover:bg-primary/90 flex items-center justify-center gap-2 rounded-xl py-3.5 text-sm font-bold transition-all duration-300 hover:scale-[1.02]"
            >
              <svg
                class="h-4 w-4"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
