  },
  {
    name: "Instagram",
    handle: "@trasciendegym",
    url: "https://www.instagram.com/trasciendegym?igsh=MmJxaHRjM2w2cG1p",
    description: "Contenido diario · Rutinas · Resultados",
    color: "from-purple-600 to-pink-500",
